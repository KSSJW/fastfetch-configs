{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "padding": {
            "top": 2
        }
    },
    "display": {
        "separator": " "
    },
    "modules": [
        {
            "type": "title",
            "key": "Host",
            "format": "{host-name}"
        },
        {
            "type": "chassis",
            "key": "|- Chassis"
        },
        {
            "type": "board",
            "key": "|- Board"
        },
        {
            "type": "cpu",
            "key": "|- CPU",
            "showPeCoreCount": true,
            "temp": true
        },
        // {
        //     "type": "cpucache",
        //     "key": "|- CPUCache",
        //     "showPeCoreCount": true,
        //     "temp": true
        // },
        // {
        //     "type": "cpuusage",
        //     "key": "|- CPUUsage",
        //     "driverSpecific": true,
        //     "temp": true
        // },
        {
            "type": "gpu",
            "key": "|- GPU",
            "driverSpecific": true,
            "temp": true
        },
        {
            "type": "memory",
            "key": "|- Memory",
            "driverSpecific": true,
            "temp": true
        },
        {
            "type": "physicalmemory",
            "key": "|- PhysicalMemory",
            "driverSpecific": true,
            "temp": true
        },
        {
            "type": "physicaldisk",
            "key": "|- PhysicalDisk",
            "temp": true
        },
        {
            "type": "battery",
            "key": "|- Battery",
            "temp": true
        },
        {
            "type": "poweradapter",
            "key": "|- PowerAdapter",
            "temp": true
        },
        {
            "type": "display",
            "key": "|- Display"
        },
        // {
        //     "type": "brightness",
        //     "key": "|- Brightness"
        // },
        // {
        //     "type": "monitor",
        //     "key": "|- Monitor"
        // },
