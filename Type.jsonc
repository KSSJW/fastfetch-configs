        //     "key": "|- Mouse"
        // },
        // {
        //     "type": "gamepad",
        //     "key": "|- GamePad"
        // },
        {
            "type": "localip",
            "key": "|- LocalIP",
            "showIpv6": false,
            "showMac": false,
            "showSpeed": false,
            "showMtu": false,
            "showLoop": false,
            "showFlags": false,
            "showAllIps": false
        },
        // {
        //     "type": "publicip",
        //     "key": "|- PublicIP",
        //     "timeout": 1000
