        {
            "type": "Packages",
            "key": "|- Packages"
        },
        {
            "type": "swap",
            "key": "|- Swap",
            "separate": true
        },
        {
            "type": "disk",
            "key": "|- Disk",
            "separate": true
        },
        // {
