        //     "key": "|- Bluetooth"
        // },
        // {
        //     "type": "bluetoothradio",
        //     "key": "|- BluetoothRadio"
        // },

        "break",

        {
            "type": "bios",
            "key": "BIOS"
        },
        {
            "type": "tpm",
            "key": "|- TPM"
        },
        {
            "type": "bootmgr",
            "key": "|- BootManager"
        },

        "break",

        {
            "type": "os",
            "key": "OS"
        },
        {
            "type": "kernel",
            "key": "|- Kernel"
        },
        {
            "type": "initsystem",
            "key": "|- InitSystem"
        },
        {
            "type": "uptime",
            "key": "|- UpTime"
